cat > .gitignore << 'EOF'
# Environment variables / secrets
.env
.env.local
.envrc

# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Test / coverage / lint cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/

# Temporary files
*.log
tempCodeRunnerFile.py
EOF.cursor/
