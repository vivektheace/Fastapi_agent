# Copy to .env and fill in real values for local development.

APP_ENV=local
LOG_LEVEL=INFO

# Set to "openai" for live LangChain agent; "mock" forces fallback (no key needed).
AI_PROVIDER=mock

OPENAI_API_KEY=
# Optional for Groq or other OpenAI-compatible providers:
# LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
HTTP_TIMEOUT_SECONDS=15.0
